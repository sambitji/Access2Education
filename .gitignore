# =============================================================
# .gitignore — Edu-Platform
# Covers: Python, ML, Backend, Frontend, IDE, OS
# =============================================================


# ╔══════════════════════════════════════════════════════════╗
# ║          🔐 SECRET FILES — KABHI PUSH MAT KARO          ║
# ║     Ye section SABSE IMPORTANT hai — dhyan se padho     ║
# ╚══════════════════════════════════════════════════════════╝

# .env files — API keys, DB passwords, JWT secrets sab yahan hote hain
# Root .env files
.env
.env.local
.env.development
.env.production
.env.staging
.env.test

# Backend specific
Backend/.env
Backend/.env.local
Backend/.env.development
Backend/.env.production
Backend/.env.staging

# Frontend specific
Frontend/.env
Frontend/.env.local
Frontend/.env.development
Frontend/.env.production
Frontend/.env.staging

# NOTE: .env.example files are NOT listed here — they should be pushed
# They contain only placeholder values (no real secrets)

# Agar koi secrets.json ya credentials.json banaye
secrets.json
credentials.json
*.secret
*.key
*.pem
*.p12
*.pfx
service-account*.json
firebase*.json
google-credentials*.json


# ╔══════════════════════════════════════════════════════════╗
# ║              🤖 ML MODELS — Large Binary Files           ║
# ╚══════════════════════════════════════════════════════════╝

# Trained model files — large hain, reproduce kiye ja sakte hain
ML/models/*.pkl
ML/models/*.joblib
ML/models/*.h5
ML/models/*.pb
ML/models/*.pt
ML/models/*.pth
ML/models/*.onnx
ML/models/model_info.json

# Lekin models folder ka existence maintain karo
!ML/models/.gitkeep


# ╔══════════════════════════════════════════════════════════╗
# ║                📦 DATA FILES — Large CSVs                ║
# ╚══════════════════════════════════════════════════════════╝

# Large dataset files
data/*.csv
data/*.xlsx
data/*.parquet
data/*.db

# Lekin example/metadata files allow karo
!data/content_metadata.json
!data/.gitkeep


