cython_debug/

# Logs
*.log
pip-log.txt
pip-delete-this-directory.txt

# Django / Flask (agar future mein use ho)
local_settings.py
db.sqlite3
db.sqlite3-journal
instance/
.webassets-cache
.scrapy

# Sphinx docs
docs/_build/
/site

# Celery
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# PyBuilder
.pybuilder/
target/

# Abstra / Cursor / Marimo
.abstra/
.cursorignore
.cursorindexingignore
marimo/_static/
marimo/_lsp/
__marimo

# PyPI config
.pypirc


